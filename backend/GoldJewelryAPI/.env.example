# ─── PayFast Pakistan credentials (paste yours here) ─────────────────────────
# Provided by PayFast after merchant onboarding (https://gopayfast.com).
PAYFAST_MERCHANT_ID=
PAYFAST_SECURED_KEY=
PAYFAST_MERCHANT_NAME=Gold Jewelry Store

# Sandbox endpoints (PayFast Pakistan UAT). Swap to production URLs when going live:
#   token URL : https://payfast.apps.net.pk/Ecommerce/api/Transaction/GetAccessToken
#   redirect  : https://payfast.apps.net.pk/Ecommerce/api/Transaction/PostTransaction
PAYFAST_TOKEN_API_URL=https://ipguat.apps.net.pk/Ecommerce/api/Transaction/GetAccessToken
PAYFAST_REDIRECT_URL=https://ipguat.apps.net.pk/Ecommerce/api/Transaction/PostTransaction

# Currency must match the PayFast merchant account (PKR for Pakistan).
PAYFAST_CURRENCY=PKR

# Public URLs PayFast will redirect the customer's browser back to.
APP_BACKEND_URL=http://localhost:5000
APP_FRONTEND_URL=http://localhost:4200
